<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Cadastro de Representantes - APECAD</title>
  <style>
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: linear-gradient(135deg, #0d1b2a, #1b263b);
      color: #fff;
      min-height: 100vh;
      padding: 30px 15px;
    }

    .container {
      max-width: 820px;
      margin: 0 auto;
    }

    .card {
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 20px;
      padding: 24px;
      backdrop-filter: blur(10px);
      box-shadow: 0 12px 40px rgba(0,0,0,0.25);
    }

    .titulo {
      margin: 0 0 10px;
      font-size: 30px;
      font-weight: 800;
      text-align: center;
    }

    .subtitulo {
      margin: 0 0 25px;
      text-align: center;
      color: #dbe7ff;
      font-size: 15px;
    }

    .status-box {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 12px;
      margin-bottom: 22px;
    }

    .status-item {
      background: rgba(255,255,255,0.08);
      border-radius: 14px;
      padding: 15px;
      text-align: center;
    }

    .status-item strong {
      display: block;
      font-size: 24px;
      margin-bottom: 6px;
      color: #ffd166;
    }

    form {
      display: grid;
      gap: 16px;
    }

    .linha {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    @media (max-width: 720px) {
      .linha {
        grid-template-columns: 1fr;
      }
    }

    .campo {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .campo label {
      font-weight: 700;
      color: #f1f5ff;
    }

    .campo input,
    .campo select {
      height: 48px;
      border: none;
      border-radius: 12px;
      padding: 0 14px;
      font-size: 15px;
      outline: none;
      background: #fff;
      color: #111;
    }

    .campo input:disabled,
    .campo select:disabled,
    button:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }

    button {
      height: 50px;
      border: none;
      border-radius: 14px;
      background: #ffd166;
      color: #111;
      font-size: 16px;
      font-weight: 800;
      cursor: pointer;
      transition: 0.2s;
    }

    button:hover {
      transform: translateY(-1px);
      filter: brightness(1.03);
    }

    .mensagem {
      margin-top: 18px;
      padding: 14px 16px;
      border-radius: 12px;
      display: none;
      font-weight: 700;
    }

    .mensagem.sucesso {
      display: block;
      background: rgba(0, 200, 83, 0.18);
      border: 1px solid rgba(0, 200, 83, 0.4);
      color: #b9ffd0;
    }

    .mensagem.erro {
      display: block;
      background: rgba(255, 82, 82, 0.16);
      border: 1px solid rgba(255, 82, 82, 0.38);
      color: #ffd0d0;
    }

    .lista {
      margin-top: 24px;
      background: rgba(255,255,255,0.06);
      border-radius: 16px;
      padding: 18px;
    }

    .lista h3 {
      margin: 0 0 12px;
      font-size: 18px;
      color: #ffd166;
    }

    .chips {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .chip {
      padding: 10px 14px;
      border-radius: 999px;
      font-size: 14px;
      font-weight: 700;
    }

    .chip.disponivel {
      background: rgba(0, 200, 83, 0.16);
      border: 1px solid rgba(0, 200, 83, 0.35);
      color: #caffd9;
    }

    .chip.ocupada {
      background: rgba(255, 209, 102, 0.15);
      border: 1px solid rgba(255, 209, 102, 0.35);
      color: #ffe7a6;
    }

    .rodape-info {
      margin-top: 18px;
      font-size: 13px;
      text-align: center;
      color: #d6def0;
    }

    .loading {
      opacity: 0.7;
      pointer-events: none;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="card" id="cardPrincipal">
      <h1 class="titulo">Cadastro de Representantes</h1>
      <p class="subtitulo">
        Cada time cadastra 2 representantes e escolhe 1 seleção disponível.
      </p>

      <div class="status-box">
        <div class="status-item">
          <strong id="totalCadastrados">0</strong>
          <span>Times cadastrados</span>
        </div>
        <div class="status-item">
          <strong id="vagasRestantes">10</strong>
          <span>Vagas restantes</span>
        </div>
        <div class="status-item">
          <strong id="totalSelecoes">12</strong>
          <span>Seleções disponíveis no sistema</span>
        </div>
      </div>

      <form id="formCadastro">
        <div class="campo">
          <label for="nomeTime">Nome do time</label>
          <input type="text" id="nomeTime" placeholder="Digite o nome do time" required />
        </div>

        <div class="linha">
          <div class="campo">
            <label for="representante1">Representante 1</label>
            <input type="text" id="representante1" placeholder="Nome completo" required />
          </div>

          <div class="campo">
            <label for="representante2">Representante 2</label>
            <input type="text" id="representante2" placeholder="Nome completo" required />
          </div>
        </div>

        <div class="campo">
          <label for="selecao">Seleção</label>
          <select id="selecao" required>
            <option value="">Carregando seleções disponíveis...</option>
          </select>
        </div>

        <button type="submit" id="btnSalvar">Salvar cadastro</button>
      </form>

      <div id="mensagem" class="mensagem"></div>

      <div class="lista">
        <h3>Seleções já escolhidas</h3>
        <div class="chips" id="chipsOcupadas"></div>
      </div>

      <div class="lista">
        <h3>Seleções disponíveis</h3>
        <div class="chips" id="chipsDisponiveis"></div>
      </div>

      <div class="rodape-info">
        O cadastro será encerrado automaticamente quando atingir 10 times.
      </div>
    </div>
  </div>

  <script>
    const API_URL = 'COLE_AQUI_SUA_URL_DO_APPS_SCRIPT';

    const form = document.getElementById('formCadastro');
    const nomeTime = document.getElementById('nomeTime');
    const representante1 = document.getElementById('representante1');
    const representante2 = document.getElementById('representante2');
    const selecao = document.getElementById('selecao');
    const btnSalvar = document.getElementById('btnSalvar');
    const mensagem = document.getElementById('mensagem');
    const cardPrincipal = document.getElementById('cardPrincipal');

    const totalCadastrados = document.getElementById('totalCadastrados');
    const vagasRestantes = document.getElementById('vagasRestantes');
    const totalSelecoes = document.getElementById('totalSelecoes');
    const chipsOcupadas = document.getElementById('chipsOcupadas');
    const chipsDisponiveis = document.getElementById('chipsDisponiveis');

    function mostrarMensagem(texto, tipo) {
      mensagem.className = `mensagem ${tipo}`;
      mensagem.textContent = texto;
    }

    function limparMensagem() {
      mensagem.className = 'mensagem';
      mensagem.textContent = '';
    }

    function setLoading(ativo) {
      if (ativo) {
        cardPrincipal.classList.add('loading');
      } else {
        cardPrincipal.classList.remove('loading');
      }
    }

    function preencherSelectSelecoes(lista) {
      selecao.innerHTML = '<option value="">Selecione uma seleção</option>';

      if (!lista || !lista.length) {
        selecao.innerHTML = '<option value="">Nenhuma seleção disponível</option>';
        return;
      }

      lista.forEach(item => {
        const option = document.createElement('option');
        option.value = item;
        option.textContent = item;
        selecao.appendChild(option);
      });
    }

    function renderChips(container, lista, classe) {
      container.innerHTML = '';

      if (!lista || !lista.length) {
        const chip = document.createElement('div');
        chip.className = `chip ${classe}`;
        chip.textContent = 'Nenhuma';
        container.appendChild(chip);
        return;
      }

      lista.forEach(item => {
        const chip = document.createElement('div');
        chip.className = `chip ${classe}`;
        chip.textContent = item;
        container.appendChild(chip);
      });
    }

    function bloquearFormulario(bloquear) {
      nomeTime.disabled = bloquear;
      representante1.disabled = bloquear;
      representante2.disabled = bloquear;
      selecao.disabled = bloquear;
      btnSalvar.disabled = bloquear;
    }

    async function carregarStatus() {
      try {
        setLoading(true);
        limparMensagem();

        const resp = await fetch(`${API_URL}?rota=listar`);
        const data = await resp.json();

        if (!data.ok) {
          mostrarMensagem(data.mensagem || 'Erro ao carregar dados.', 'erro');
          return;
        }

        totalCadastrados.textContent = data.totalCadastrados ?? 0;
        vagasRestantes.textContent = data.vagasRestantes ?? 0;
        totalSelecoes.textContent = 12;

        preencherSelectSelecoes(data.selecoesDisponiveis || []);
        renderChips(chipsOcupadas, data.selecoesEscolhidas || [], 'ocupada');
        renderChips(chipsDisponiveis, data.selecoesDisponiveis || [], 'disponivel');

        if (data.cadastroEncerrado) {
          bloquearFormulario(true);
          mostrarMensagem('Cadastro encerrado: o limite de 10 times já foi atingido.', 'erro');
        } else {
          bloquearFormulario(false);
        }

      } catch (erro) {
        mostrarMensagem('Erro ao conectar com a API.', 'erro');
        console.error(erro);
      } finally {
        setLoading(false);
      }
    }

    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      limparMensagem();

      const payload = {
        rota: 'cadastrar',
        nomeTime: nomeTime.value.trim(),
        representante1: representante1.value.trim(),
        representante2: representante2.value.trim(),
        selecao: selecao.value
      };

      if (!payload.nomeTime || !payload.representante1 || !payload.representante2 || !payload.selecao) {
        mostrarMensagem('Preencha todos os campos.', 'erro');
        return;
      }

      if (payload.representante1.toLowerCase() === payload.representante2.toLowerCase()) {
        mostrarMensagem('Os dois representantes devem ser diferentes.', 'erro');
        return;
      }

      try {
        setLoading(true);

        const resp = await fetch(API_URL, {
          method: 'POST',
          headers: {
            'Content-Type': 'text/plain;charset=utf-8'
          },
          body: JSON.stringify(payload)
        });

        const data = await resp.json();

        if (!data.ok) {
          mostrarMensagem(data.mensagem || 'Erro ao salvar cadastro.', 'erro');
          await carregarStatus();
          return;
        }

        mostrarMensagem(data.mensagem || 'Cadastro realizado com sucesso.', 'sucesso');
        form.reset();
        await carregarStatus();

      } catch (erro) {
        console.error(erro);
        mostrarMensagem('Erro ao enviar cadastro.', 'erro');
      } finally {
        setLoading(false);
      }
    });

    carregarStatus();
  </script>
</body>
</html>
